{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016nUvPrsA4cdan4MfMmyp3y","type":"tool_result","content":"1\t// Types\n2\texport type {\n3\t  Tile,\n4\t  TileId,\n5\t  TileSuit,\n6\t  TileCategory,\n7\t  TileValue,\n8\t  WindValue,\n9\t  DragonValue,\n10\t  FlowerValue,\n11\t  SuitedTile,\n12\t  WindTile,\n13\t  DragonTile,\n14\t  FlowerTile,\n15\t  JokerTile,\n16\t} from \"./types/tiles\";\n17\t\n18\texport type {\n19\t  GameState,\n20\t  GamePhase,\n21\t  TurnPhase,\n22\t  SeatWind,\n23\t  PlayerState,\n24\t  ExposedGroup,\n25\t  GroupIdentity,\n26\t  CallWindowState,\n27\t  ActionResult,\n28\t  ResolvedAction,\n29\t  WallGameResult,\n30\t  MahjongGameResult,\n31\t  PaymentBreakdown,\n32\t  GameResult,\n33\t} from \"./types/game-state\";\n34\t\n35\texport type {\n36\t  GameAction,\n37\t  StartGameAction,\n38\t  DrawTileAction,\n39\t  DiscardTileAction,\n40\t  PassCallAction,\n41\t} from \"./types/actions\";\n42\t\n43\texport type {\n44\t  NMJLCard,\n45\t  CardCategory,\n46\t  HandPattern,\n47\t  GroupPattern,\n48\t  GroupType,\n49\t  TileRequirement,\n50\t  TileSpecific,\n51\t} from \"./types/card\";\n52\t\n53\t// Constants\n54\texport {\n55\t  TILE_COUNT,\n56\t  JOKER_COUNT,\n57\t  COPIES_PER_TILE,\n58\t  COPIES_PER_FLOWER,\n59\t  MAX_PLAYERS,\n60\t  SEATS,\n61\t  SUITS,\n62\t  WINDS,\n63\t  DRAGONS,\n64\t  FLOWERS,\n65\t  TILE_VALUES,\n66\t  GROUP_TYPES,\n67\t  GROUP_SIZES,\n68\t  DEFAULT_CALL_WINDOW_MS,\n69\t  MIN_CALL_WINDOW_MS,\n70\t  MAX_CALL_WINDOW_MS,\n71\t} from \"./constants\";\n72\t\n73\t// Card\n74\texport { loadCard } from \"./card/card-loader\";\n75\texport { validateHand } from \"./card/pattern-matcher\";\n76\texport type { MatchResult } from \"./card/pattern-matcher\";\n77\texport {\n78\t  isJokerEligibleGroup,\n79\t  canSubstituteJoker,\n80\t  validateJokerExchange,\n81\t} from \"./card/joker-eligibility\";\n82\texport type { ExchangeResult } from \"./card/joker-eligibility\";\n83\texport {\n84\t  validateExposure,\n85\t  validateHandWithExposure,\n86\t  filterAchievableByExposure,\n87\t} from \"./card/exposure-validation\";\n88\texport type { ExposureResult } from \"./card/exposure-validation\";\n89\t\n90\t// Scoring\n91\texport { calculatePayments, calculateWallGamePayments, lookupHandPoints } from \"./engine/scoring\";\n92\texport type { CalculatePaymentsParams, ScoringResult } from \"./engine/scoring\";\n93\t\n94\t// Engine\n95\texport { createAllTiles, createWall } from \"./engine/state/wall\";\n96\texport { dealTiles } from \"./engine/state/dealing\";\n97\texport { createGame } from \"./engine/state/create-game\";\n98\texport { createLobbyState, handleAction } from \"./engine/game-engine\";\n99\texport { handleDrawTile, advanceTurn } from \"./engine/actions/draw\";\n100\texport { handleDiscardTile } from \"./engine/actions/discard\";\n101\texport { handlePassCall, closeCallWindow } from \"./engine/actions/call-window\";\n102\t"}]},"parent_tool_use_id":"toolu_01EYtCFSxDAtLkxfVg8xqi5G","session_id":"e018b2a0-f3f1-40e1-98cc-69fb37f4a59e","uuid":"530fe872-efd1-4a95-b2f3-05586aa60338","timestamp":"2026-03-28T03:09:09.174Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GWgoJfavUdqLBMoJj35YkF","type":"tool_result","content":"1\timport type { GameState, ActionResult } from \"../../types/game-state\";\n2\timport type { DiscardTileAction } from \"../../types/actions\";\n3\t\n4\t/**\n5\t * Handle DISCARD_TILE action: validate turn, phase, tile ownership, and Joker restriction,\n6\t * then remove tile from rack, add to discard pool, and open the call window.\n7\t * Follows validate-then-mutate pattern.\n8\t */\n9\texport function handleDiscardTile(state: GameState, action: DiscardTileAction): ActionResult {\n10\t  // 1. Validate — no mutations above this line\n11\t  if (state.gamePhase !== \"play\") {\n12\t    return { accepted: false, reason: \"WRONG_PHASE\" };\n13\t  }\n14\t  if (state.currentTurn !== action.playerId) {\n15\t    return { accepted: false, reason: \"NOT_YOUR_TURN\" };\n16\t  }\n17\t  if (state.turnPhase !== \"discard\") {\n18\t    return { accepted: false, reason: \"MUST_DRAW_FIRST\" };\n19\t  }\n20\t\n21\t  const player = state.players[action.playerId];\n22\t  if (!player) throw new Error(`handleDiscardTile: no player found for id '${action.playerId}'`);\n23\t  const tileIndex = player.rack.findIndex((t) => t.id === action.tileId);\n24\t  if (tileIndex === -1) {\n25\t    return { accepted: false, reason: \"TILE_NOT_IN_RACK\" };\n26\t  }\n27\t\n28\t  const tile = player.rack[tileIndex];\n29\t  if (tile.category === \"joker\") {\n30\t    return { accepted: false, reason: \"CANNOT_DISCARD_JOKER\" };\n31\t  }\n32\t\n33\t  // 2. Mutate — only reached if all validation passed\n34\t  player.rack.splice(tileIndex, 1);\n35\t  player.discardPool.push(tile);\n36\t  state.lastDiscard = { tile, discarderId: action.playerId };\n37\t\n38\t  // 3. Open call window — all players get a chance to call the discarded tile\n39\t  // Wall depletion does NOT skip the call window; the last discard can still be called (GDD FR20)\n40\t  state.turnPhase = \"callWindow\";\n41\t  state.callWindow = {\n42\t    status: \"open\",\n43\t    discardedTile: tile,\n44\t    discarderId: action.playerId,\n45\t    passes: [action.playerId],\n46\t    calls: [],\n47\t    openedAt: Date.now(),\n48\t  };\n49\t\n50\t  // 4. Return result\n51\t  return {\n52\t    accepted: true,\n53\t    resolved: { type: \"DISCARD_TILE\", playerId: action.playerId, tileId: action.tileId },\n54\t  };\n55\t}\n56\t"}]},"parent_tool_use_id":"toolu_01EYtCFSxDAtLkxfVg8xqi5G","session_id":"e018b2a0-f3f1-40e1-98cc-69fb37f4a59e","uuid":"eb1aee1e-f605-4fb5-b293-b728484625c5","timestamp":"2026-03-28T03:09:09.175Z"}
{"type":"system","subtype":"task_progress","task_id":"a4d240d0bbea88fb6","tool_use_id":"toolu_01JHPzXLrwyTqoxi6N3jdNCi","description":"Reading _bmad-output/planning-artifacts/ux-design-specification.md","usage":{"total_tokens":73917,"tool_uses":7,"duration_ms":20070},"last_tool_name":"Read","uuid":"8785d939-e65d-4cf4-bb3b-db4a16ed0620","session_id":"e018b2a0-f3f1-40e1-98cc-69fb37f4a59e"}
{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_018r21j2H4LTDkCdomHjDBmU","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01TKCjxUmhBXhqcRzdDjLdvu","name":"Read","input":{"file_path":"/Users/rchoi/Personal/mahjong-game/_bmad-output/planning-artifacts/ux-design-specification.md","offset":500,"limit":500},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":37278,"cache_read_input_tokens":36594,"cache_creation":{"ephemeral_5m_input_tokens":37278,"ephemeral_1h_input_tokens":0},"output_tokens":35,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01JHPzXLrwyTqoxi6N3jdNCi","session_id":"e018b2a0-f3f1-40e1-98cc-69fb37f4a59e","uuid":"6de19b57-ab0e-42f2-abaf-f9d382c624b9"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TKCjxUmhBXhqcRzdDjLdvu","type":"tool_result","content":"500\t- **Regular (400):** Body text, chat messages, secondary information\n501\t- **No light/thin weights (100-300):** Unreadable on mobile screens for older eyes. Not used anywhere.\n502\t\n503\t**Line Height:**\n504\t- Headings: 1.2-1.3\n505\t- Body/UI text: 1.5-1.6\n506\t- Generous line-height is a readability feature for this demographic, not a style choice\n507\t\n508\t#### Spacing Scale\n509\t\n510\tConsistent 4px-based spacing scale defined in UnoCSS theme:\n511\t\n512\t`4 / 8 / 12 / 16 / 24 / 32 / 48 / 64 / 96`\n513\t\n514\tBias toward generous spacing — `p-4` (16px) is the minimum for interactive element padding. `gap-3` (12px) minimum between interactive elements. Minimum 8px gap between adjacent interactive elements (prevents mis-taps on neighboring buttons). Whitespace IS elegance for this audience.\n515\t\n516\t#### Border Radius Scale\n517\t\n518\t- `radius-sm` (4px) — Subtle rounding for small elements (badges, indicators)\n519\t- `radius-md` (8px) — Standard for panels, cards, buttons\n520\t- `radius-lg` (12px) — Tiles (acrylic feel), larger containers\n521\t- `radius-full` — Avatar circles, player presence indicators\n522\t\n523\t#### Shadow Scale\n524\t\n525\tWarm-toned shadows (not pure black) for material depth:\n526\t- `shadow-tile` — Subtle drop shadow for tile depth on felt\n527\t- `shadow-panel` — Medium elevation for UI panels and overlays\n528\t- `shadow-modal` — Strong elevation for overlays (NMJL card, celebration)\n529\t\n530\t#### Tile Display\n531\t\n532\t- `tile-min-width` — Minimum tile face width for legibility: 28-32px. The corner Arabic index on suited tiles (Craks, Bams, Dots) must be readable at the smallest rendered size for the 40-70+ demographic.\n533\t- Tiles rendered below `tile-min-width` should provide a \"tap to zoom\" affordance.\n534\t- Used to validate: celebration fan-out tile size, \"show hands\" reveal, exposed groups on small screens.\n535\t- Player rack tiles are always larger than this minimum; this constraint applies to tiles displayed outside the rack.\n536\t\n537\t#### Animation Tokens\n538\t\n539\tDefined as CSS custom properties, consumed by Motion for Vue AND any CSS transitions:\n540\t\n541\t- **Tactile:** `--timing-tactile: 120ms` with `--ease-tactile: ease-out` — tile lift, button press, panel open, rack snap\n542\t- **Expressive:** `--timing-expressive: 400ms` with `--ease-expressive: cubic-bezier(0.16, 1, 0.3, 1)` — Charleston glide, call trajectory, celebration fan-out, mood crossfade\n543\t- **Entrance:** `--timing-entrance: 200ms` with `--ease-entrance: ease-out` — elements appearing (call buttons, notifications)\n544\t- **Exit:** `--timing-exit: 150ms` with `--ease-exit: ease-in` — elements disappearing (call window closing, toast dismissal)\n545\t- **Reduced motion:** 0ms duration for ALL animations (respects `prefers-reduced-motion`). Motion for Vue handles this natively for its animations. For any raw CSS transitions, reference the custom properties — they'll be overridden to 0ms under the media query.\n546\t- **Rule:** No raw CSS `transition` properties with hardcoded durations. Use Motion for Vue for all animated elements, or reference the animation custom properties if CSS transitions are unavoidable. This ensures reduced motion is never accidentally bypassed.\n547\t\n548\t#### Accessibility Tokens\n549\t\n550\t- **Focus ring:** 2px solid, 2px offset — context-adaptive color: `focus-ring-on-chrome` (#8C7038, 4.12:1 on cream), `focus-ring-on-felt` (#F5F0E8, 5.42:1 on teal), `focus-ring-on-dark` (#C4A35A, 5.95:1 on charcoal). All meet WCAG 3:1 UI component contrast. Components apply the appropriate ring token based on their background context.\n551\t- **Minimum tap target:** 44px (defined as UnoCSS shortcut `min-tap` → `min-h-11 min-w-11`)\n552\t- **Minimum gap between adjacent interactive elements:** 8px — prevents mis-taps on neighboring buttons\n553\t- **Contrast requirements:** WCAG AA — 4.5:1 for normal text, 3:1 for large text (18px+ bold or 24px+ regular) and UI components. All color token pairings pre-validated.\n554\t- **Keyboard Tab zones:** Focus navigation follows the GDD's zone model (Rack → Action buttons → NMJL card → Chat → Controls). Each zone is a focus-trap region. Tab moves between zones; Arrow keys navigate within zones; Enter confirms; Escape exits chat focus. The focus ring token applies within this zone architecture.\n555\t\n556\t### Spatial Layout Specification\n557\t\n558\t**Primary layout target: iPad landscape (1024px)**\n559\t\n560\t```\n561\t┌─────────────────────────────────────────────────────────┐\n562\t│  [Opponent Top]          [Table Center]     [NMJL Card] │\n563\t│  video + name + exposed   wall counter      sidebar     │\n564\t│                            discard pools    (~260-300px) │\n565\t│ [Opp    ┌──────────────────────────┐  [Opp              │\n566\t│  Left]  │                          │   Right]            │\n567\t│  video  │     FELT TABLE           │   video             │\n568\t│  name   │     (game area)          │   name              │\n569\t│  exposed│                          │   exposed           │\n570\t│         └──────────────────────────┘                     │\n571\t│                                                          │\n572\t│  [Action Zone]  [Player Rack - 13/14 tiles]   [Social]  │\n573\t│  Mahjong btn    drag-to-arrange, tap-to-act    chat     │\n574\t│  call buttons   sort button                    reactions │\n575\t│  turn indicator discard confirm in zone        A/V      │\n576\t└─────────────────────────────────────────────────────────┘\n577\t```\n578\t\n579\t**Mobile layout (<1024px, including iPad portrait):**\n580\t\n581\t```\n582\t┌──────────────────────────┐\n583\t│ [Opp Left] [Top] [Right] │  ← compressed: small avatars/names\n584\t│ ┌──────────────────────┐ │\n585\t│ │                      │ │\n586\t│ │    FELT TABLE        │ │  ← discard pools compressed\n587\t│ │    (game area)       │ │\n588\t│ │                      │ │\n589\t│ └──────────────────────┘ │\n590\t│ [Action Zone - full width│  ← call buttons, Mahjong btn\n591\t│  above rack]             │\n592\t│ [Player Rack - horizontal│  ← scrolls if tiles exceed width\n593\t│  scroll if needed]       │\n594\t│ [Bottom Bar]             │  ← NMJL toggle, chat toggle, A/V\n595\t└──────────────────────────┘\n596\t```\n597\t\n598\t- **NMJL Card:** Full-screen overlay on mobile (toggle from bottom bar). Sidebar (~260-300px) on desktop, always visible by default but collapsible to gain table space.\n599\t- **Chat:** Slide-up panel on mobile (toggle from bottom bar). Docked panel on desktop.\n600\t- **Rack scrolling:** On phone viewports where 13-14 tiles would shrink below `tile-min-width`, the rack scrolls horizontally. Tiles never shrink below minimum — scrolling is the phone adaptation, not shrinking.\n601\t\n602\t**Named Layout Trade-offs:**\n603\t\n604\t1. **Sidebar width vs. table space (desktop):** NMJL sidebar needs ~260-300px for hand pattern legibility. On 1024px iPad landscape, this leaves ~724-764px for the game table. Sidebar should be collapsible even on desktop as an escape valve.\n605\t\n606\t2. **Video thumbnail size vs. game elements:** Video frames are first-class layout elements, but on iPad landscape with sidebar, four meaningful thumbnails (~120×90px) consume significant edge space. Layout must work identically with video OR avatar fallbacks — no restructuring when cameras toggle or when Epic 6B is deferred.\n607\t\n608\t3. **Rack tile size vs. tile count:** 13-14 tiles at ~50px each fit on iPad landscape (with sidebar). On phone portrait (375px), ~25px per tile is below `tile-min-width`. Phone racks MUST horizontally scroll. This is an explicit design decision, not a bug.\n609\t\n610\t**Call window on phone:** The 44px/8px/20px constraints may require vertical button stacking or adaptive sizing when 4 call options appear simultaneously on phone viewports (<768px). This specific layout must be resolved during Epic 5A — flagged as a design decision, not deferred.\n611\t\n612\t### Customization Strategy\n613\t\n614\t#### Enforced by Tooling (defined in `uno.config.ts`)\n615\t\n616\tThese rules are enforced by the UnoCSS config — the developer uses token names and shortcuts, and consistency is automatic:\n617\t\n618\t- All color tokens (surfaces, text, suits, states, guidance, moods, celebration)\n619\t- Typography role shortcuts (`text-game-critical`, `text-interactive`, `text-body`, `text-card-pattern`, `text-secondary`)\n620\t- Spacing scale, border radius scale, shadow scale\n621\t- `min-tap` shortcut (44px min-h/min-w)\n622\t- Animation custom properties (durations and easings)\n623\t- Focus ring style\n624\t- Mood-switching CSS class mechanism\n625\t\n626\t**Enforcement rule:** No raw hex color values in `.vue` files — always use token names. If a lint rule can flag this, add it.\n627\t\n628\t#### Enforced by Discipline (developer self-enforces)\n629\t\n630\tThese rules cannot be automatically enforced and require developer awareness:\n631\t\n632\t- Toast stacking limits (max 1 on phone, 2 on tablet/desktop, auto-dismiss 3s, never overlap rack or action buttons)\n633\t- Overlay context preservation on phone (overlays must preserve rack visibility or provide comparison mechanism)\n634\t- Dark mode testing after completing each component (run the app in dark mode for 5 minutes)\n635\t- Minimum 8px gap between adjacent interactive elements\n636\t- All interactive elements validated at 375px viewport width (iPhone SE)\n637\t- Primitive extraction timing (extract after first components, not before)\n638\t- Tab zone focus-trap implementation per GDD keyboard navigation model\n639\t\n640\t#### Shared UI Primitives\n641\t\n642\t**Extraction strategy:** Do NOT build primitives in isolation as Epic 5A Story 1. Instead, build the first 3-4 feature components (Tile, TileRack, DiscardPool, CallButtons), then extract shared patterns into primitives as a dedicated refactoring story before Epic 5A closes. Primitives derived from real components are better than primitives imagined in advance.\n643\t\n644\t**Primitives to extract:**\n645\t\n646\t| Primitive | Usage |\n647\t|---|---|\n648\t| **BaseButton** | Call buttons, Mahjong button, pass button, rematch, sort, settings toggles. Consistent 44px min target, press states, focus ring, gold accent styling. |\n649\t| **BasePanel** | Chat panel, settings panel, NMJL sidebar, scoreboard. Consistent background, border, shadow, radius. |\n650\t| **BaseBadge** | Turn indicator, wall counter, player status dot, reconnecting indicator. Small status element pattern. |\n651\t| **BaseToast** | Setting change notification, turn nudge, \"Sound is on\" toast, reconnecting message. Consistent enter/exit animation, auto-dismiss, positioning. |\n652\t| **BaseOverlay** | NMJL card overlay (mobile), celebration overlay, Charleston direction overlay. Consistent backdrop, enter/exit, scroll behavior. |\n653\t| **BaseInput** | Join screen display name, chat message input, Table Talk Report description. Consistent border, focus ring, font size (`text-interactive`), padding. |\n654\t| **BaseToggle** | Hint toggle, Joker rules toggle, audio toggles, dark mode override. Consistent switch styling. |\n655\t| **BaseSelect** | Card year selector (post-MVP), dealing style selector. Consistent dropdown styling. |\n656\t| **BaseNumberStepper** | Timer setting (15-30 sec). Consistent increment/decrement control. |\n657\t| **MobileBottomBar** | Phone-only persistent toggle bar for NMJL card, chat, and A/V controls. Fixed to bottom, above safe area insets. |\n658\t\n659\t**Shared interaction pattern — TileSelectionAction:**\n660\t\"Select N tiles from rack for an action\" appears in Charleston (select 3 to pass), call confirmation (select tiles to expose), and Joker exchange (select matching tile). This should be a shared composable or component — selection state, progress indicator (\"2 of 3 selected\"), confirm/cancel — not rebuilt three times.\n661\t\n662\t**Feature components built per epic (consuming shared primitives):**\n663\t\n664\t| Epic | Components Introduced |\n665\t|---|---|\n666\t| **Epic 5A (Core Game UI)** | Tile, TileRack, DiscardPool, CallButtons, MahjongButton, ScoreBoard, GameTable layout, TurnIndicator → then extract shared primitives |\n667\t| **Epic 3B (Charleston)** | CharlestonZone, DirectionIndicator, PassButton, TileSelector (using TileSelectionAction) |\n668\t| **Epic 6A (Chat & Reactions)** | ChatPanel, ChatMessage, ReactionBar, ReactionBubble |\n669\t| **Epic 5B (Remaining UI)** | NMJLCardSidebar, NMJLCardOverlay, WallCounter, HandGuidanceHighlight, SettingsPanel, RematchButton |\n670\t| **Epic 6B (Voice/Video)** | PlayerPresence, VideoThumbnail, AvatarFallback, TalkingIndicator, AVControls |\n671\t| **Epic 7 (Visual Polish)** | CelebrationOverlay, FeltTexture, MoodTransition, AudioControls |\n672\t\n673\t**No component library documentation for MVP.** Components are self-documenting through their Vue SFC structure, props typing, and co-located tests. A Storybook or similar catalog is post-MVP scope.\n674\t\n675\t## Defining Core Experience\n676\t\n677\t### The Defining Experience\n678\t\n679\t**\"Play Mahjong with your friends like you're all at the same table.\"**\n680\t\n681\tThe defining experience of Mahjong Night is not a single interaction or mechanic — it is the feeling of social co-presence through structured play. The game provides rhythm and ritual; the social layer provides warmth and connection. Every feature, animation, and design decision exists in service of one test: **\"Did it feel like game night?\"**\n682\t\n683\tThe four peak expressions of this defining experience:\n684\t\n685\t1. **\"The Gathering\"** — The moment all four seats fill, voices overlap, and someone says \"Hey! You made it!\" This is the moment the product delivers on its promise before a single tile is drawn. The Arriving mood exists to stage this moment.\n686\t2. **The Charleston** — All four players active simultaneously, voices overlapping with groans, laughter, and strategy. The game and social layer are completely fused.\n687\t3. **The turn rhythm with conversation** — Play your turn, chat while others play theirs, react to a bold call. The game provides structure; socializing fills the spaces between turns.\n688\t4. **The Mahjong declaration as shared spectacle** — Voice chat erupts, all four players experience the emotional peak together. The celebration is staged for the audience, not just the actor.\n689\t\n690\tThe experience degrades gracefully — avatar presence, text chat, and automatic reconnection preserve the feeling of togetherness even when voice or video falters. The defining experience must be resilient, not fragile.\n691\t\n692\t### Player Mental Model\n693\t\n694\tPlayers compare Mahjong Night to **the physical table**, not to other apps. Their reference is sitting in a friend's living room with snacks and conversation. Their mental model:\n695\t\n696\t- \"I can see everyone\" — faces arranged around a table\n697\t- \"I can hear the conversation\" — cross-talk, teasing, gasping, laughter\n698\t- \"I can read the table\" — discards, exposures, wall count, all visible at a glance\n699\t- \"The game flows naturally\" — no one explains the UI, play just happens\n700\t\n701\tWhat players hate about existing digital Mahjong: silent, sterile, lonely. Mechanically correct but socially dead — solitaire with extra steps. The gap Mahjong Night fills is not \"better Mahjong\" but \"actual game night.\"\n702\t\n703\t### Success Criteria\n704\t\n705\tThe core experience succeeds when:\n706\t\n707\t1. **Players forget the screen** — The interface disappears and the social experience takes over\n708\t2. **Voice chat sounds like the physical table** — Laughter, groaning, teasing, strategy talk, cross-conversation\n709\t3. **\"Same time next week?\"** — The group returns not because the game was good, but because the evening was good\n710\t4. **The least technical player never needed help** — The UI was clear enough that no one had to coach anyone through it\n711\t5. **Players show it to friends who weren't playing** — Screenshots of the celebration, voice chat stories, \"you have to try this\"\n712\t6. **Measurable social proxies** — Time from link tap to hearing a friend's voice (<15 seconds target). Percentage of sessions with all four players audio-connected within 2 minutes. Average session length within target range (60-90 min). Rematch rate after game completion.\n713\t\n714\t### Novel vs. Established Patterns\n715\t\n716\tThe core experience uses **established patterns combined in a way no Mahjong app has done**:\n717\t\n718\t- **Established:** Video chat, link-based joining, touch-based tile games, real-time multiplayer\n719\t- **Novel combination:** Treating voice/video, game mechanics, and social features as one fused experience rather than a game with social features bolted on\n720\t- **Closest precedent:** Jackbox Games — social-first, non-gamer-first — but Jackbox is party chaos while Mahjong Night is intimate ritual\n721\t- **Semi-novel pattern:** Voice chat as default-on with game-aware audio design. Tile sounds and UI audio coexist with conversation rather than competing. Most games treat voice as optional; here it IS the product.\n722\t\n723\t### Experience Mechanics\n724\t\n725\t**1. Initiation:**\n726\tA friend texts a link. The player taps it, types their name, and arrives at a table where faces and voices are already present. The invitation is to a *gathering*, not a game lobby. The Arriving mood (warm, social, faces prominent) confirms: you're in the right place.\n727\t\n728\t**2. Interaction:**\n729\tPlayers see friends' faces, hear their voices, and play Mahjong through clear, predictable actions. The social layer is always present — reactions, chat, voice — woven into every game moment. The game provides ritual structure (Charleston, turns, calls, declarations); the social layer provides the warmth and spontaneity that make it game night.\n730\t\n731\t**3. Feedback:**\n732\tSocial feedback is the primary feedback system. Friends' reactions convey more than any UI animation: groans during the Charleston, \"nice call!\" over voice chat, eruption at a Mahjong declaration. The UI's role is to *stage* these social moments — making key game events visible and dramatic enough to provoke group reactions — not to replace human feedback with digital feedback.\n733\t\n734\t**4. Completion:**\n735\tThe game ends, but game night doesn't. The Lingering mood creates breathing room: scoreboard as conversation piece, optional hand reveal for discussion and learning, one-tap rematch. The transition from one game to the next mirrors reshuffling physical tiles — no friction, no re-setup, just the rhythm of the evening continuing.\n736\t\n737\t## Visual Design Foundation\n738\t\n739\t### Color System\n740\t\n741\t**Palette Philosophy: Warm Modern Elegance**\n742\t\n743\tThe color system draws from lifestyle Mahjong brands (That's Mahj, Oh My Mahjong) rather than gaming aesthetics. The palette communicates \"quality\" and \"taste\" — signals this audience reads instantly. Three material layers define the visual experience:\n744\t\n745\t1. **Felt Layer** — Deep teal (`felt-teal`, ~#2A6B6B) with CSS grain/noise overlay. The dominant surface during gameplay. Evokes the real felt surface where physical tiles sit.\n746\t2. **Chrome Layer** — Warm cream (`chrome-surface`, ~#F5F0E8) for UI panels, controls, and information displays. The dominant surface during Arriving and Lingering moods.\n747\t3. **Accent Layer** — Brushed matte gold (`gold-accent`, ~#C4A35A) for interactive highlights, focus rings, and celebratory moments. The connective thread across all three moods.\n748\t\n749\t**Color serves game state, not decoration.** The suit colors (Bamboo green, Crack red, Dot blue) are the primary vibrancy source — tile faces should pop against the muted, sophisticated chrome. State colors (turn-active warm glow, call-window alert, success green, error soft coral, warning amber) communicate game events without competing with tile readability.\n750\t\n751\t**Mood-specific gold temperature:** The gold accent shifts subtly between moods to reinforce emotional temperature: slightly warmer/amber during Arriving (candlelit gathering energy), slightly cooler/brass during Playing (focused game-time clarity), and softer/muted during Lingering (relaxed post-game warmth). Same gold family, different emotional weight — implemented as mood-specific token overrides via the root CSS class.\n752\t\n753\t**Dark mode** inverts the chrome layer (warm cream → warm charcoal ~#2C2A28) while the felt and accent layers remain constant. The game table looks the same; the surrounding UI adapts. Dark mode follows system preference — never forced, never the only option.\n754\t\n755\t**Contrast Validation (computed against reference hex values):**\n756\t\n757\t| Pairing | Ratio | WCAG AA | Notes |\n758\t|---|---|---|---|\n759\t| `text-primary` (#2C2420) on `chrome-surface` (#F5F0E8) | 13.41:1 | PASS (normal) | Primary text on light chrome — excellent |\n760\t| `text-on-felt` (white) on `felt-teal` (#2A6B6B) | 6.15:1 | PASS (normal) | Text on game table — good |\n761\t| `text-primary` (#2C2420) on `gold-accent` (#C4A35A) | 5.95:1 | PASS (normal) | Dark text on gold-filled buttons — good |\n762\t| `gold-accent` (#C4A35A) on `chrome-surface-dark` (#2C2A28) | 5.95:1 | PASS (normal) | Gold on dark chrome — good |\n763\t| `text-on-dark` (~#E8E0D4) on `chrome-surface-dark` (#2C2A28) | 10.92:1 | PASS (normal) | Light text on dark chrome — excellent |\n764\t| `chrome-surface` (#F5F0E8) on `felt-teal` (#2A6B6B) | 5.42:1 | PASS (normal) | Chrome elements over felt — good |\n765\t| `gold-accent` (#C4A35A) on `chrome-surface` (#F5F0E8) | 2.12:1 | **FAIL** | See fix below |\n766\t| White (#FFFFFF) on `gold-accent` (#C4A35A) | 2.40:1 | **FAIL** | See fix below |\n767\t| `state-error` (#E07A5F) on `chrome-surface` (#F5F0E8) | 2.60:1 | **FAIL** | See fix below |\n768\t\n769\t**Fixes for failing pairings:**\n770\t\n771\t1. **Gold-filled buttons use `text-primary` (dark text), not white text.** Dark text on gold passes at 5.95:1. The button hierarchy table (see UX Consistency Patterns) is corrected to specify `text-primary` on gold-filled Primary buttons.\n772\t\n773\t2. **Focus ring is context-adaptive (three tokens instead of one):**\n774\t   - `focus-ring-on-chrome`: Darker gold (#8C7038) — 4.12:1 against `chrome-surface`. PASS.\n775\t   - `focus-ring-on-felt`: Cream (#F5F0E8) — 5.42:1 against `felt-teal`. PASS.\n776\t   - `focus-ring-on-dark`: Original gold (#C4A35A) — 5.95:1 against `chrome-surface-dark`. PASS.\n777\t   - Components apply the appropriate ring token based on their background context.\n778\t\n779\t3. **Error state is mode-adaptive (two tokens):**\n780\t   - `state-error` light mode: Deeper coral (#B8553A) — 4.21:1 against `chrome-surface`. PASS.\n781\t   - `state-error` dark mode: Lighter coral (#E8896E) — 5.61:1 against `chrome-surface-dark`. PASS.\n782\t   - Error inline messages use a subtle coral background tint with `text-primary` text (13:1+), not colored text alone.\n783\t\n784\t**Reference values note:** All color values marked with ~ are reference targets expressing design intent, not final implementation values. Final hex values will be tuned during Epic 5A implementation. The contrast validation above confirms the reference values are viable starting points. The token architecture accommodates tuning without structural changes — any value changes must be re-validated against these pairings.\n785\t\n786\t### Typography System\n787\t\n788\t**Type Pairing: Warmth Meets Precision**\n789\t\n790\t- **UI Font (primary):** Humanist sans-serif — warm, readable, never clinical. Candidates: Inter, Source Sans 3, or Nunito. Must support weights 400-700 and render crisply at 14-20px on iPad displays.\n791\t- **Display Font (accent):** Editorial serif — used sparingly for the \"Mahjong Night\" wordmark, celebration \"Mahjong!\" text, and scoreboard headers. Fewer than 10 text elements use this font.\n792\t- **Card Font (functional):** Monospace or tabular figures for NMJL hand notation. D, 0, and O must be visually distinct at 16px.\n793\t\n794\t**Display font optimization:** The display font is used in fewer than 10 text elements. To protect the 5MB bundle target: subset the font aggressively to only the characters needed, or render the \"Mahjong Night\" wordmark as an SVG to eliminate one font load entirely. Evaluate during Epic 5A — if the wordmark is SVG and celebration/scoreboard text is the only remaining use, a system serif fallback may suffice.\n795\t\n796\t**Type Scale Strategy:** Named semantic roles (`text-game-critical`, `text-interactive`, `text-body`, `text-card-pattern`, `text-secondary`) prevent size drift across 13 epics. The developer picks a role, not a pixel value. No text below 14px anywhere. No light/thin weights (100-300) — unreadable for older eyes on glass screens.\n797\t\n798\t**Readability is the design:** Generous line heights (1.5-1.6 for body), semibold for all interactive elements, and high-contrast text tokens ensure that \"beautiful\" and \"readable\" are the same thing for this audience.\n799\t\n800\t### Spacing & Layout Foundation\n801\t\n802\t**Spatial Philosophy: Generous Space IS Elegance**\n803\t\n804\tThe 4px-based spacing scale (4/8/12/16/24/32/48/64/96) biases toward generous values. For this audience, cramped interfaces signal \"cheap\" and \"confusing.\" Whitespace signals \"quality\" and \"confidence.\"\n805\t\n806\t**Key spatial rules:**\n807\t- 16px minimum padding for interactive elements\n808\t- 12px minimum gap between interactive elements\n809\t- 8px minimum between adjacent tap targets (prevents mis-taps)\n810\t- 44px minimum dimension for all tap targets\n811\t- `tile-min-width` is **30px** — committed as a concrete implementation value, not a range. If playtesting during Epic 5A reveals legibility issues at 30px for the 40-70+ demographic, adjust upward. Starting with a definite value unblocks Tile component development immediately.\n812\t\n813\t**Layout is iPad-first at 1024px.** The felt table occupies the center, player presence (video/avatar) lives at cardinal seat positions, the rack anchors the bottom, and the NMJL card sidebar (~260-300px) sits right. This layout adapts upward to desktop (more space for video and card detail) and downward to phone (progressive disclosure, overlays replace sidebars, rack scrolls horizontally).\n814\t\n815\t### Accessibility Considerations\n816\t\n817\t**Accessibility is not a separate concern — it IS the design for this audience.**\n818\t\n819\t- **WCAG AA contrast** on all text/background pairings (4.5:1 normal text, 3:1 large text and UI components). Pre-validated at the token level.\n820\t- **44px minimum tap targets** — generous sizing is elegance, not accommodation.\n821\t- **Color-blind safe tile identification** — each suit has shape/pattern distinguishers in addition to color. Hand guidance uses gold/neutral highlights, never suit colors.\n822\t- **Reduced motion** — all animation durations override to 0ms under `prefers-reduced-motion`. Motion for Vue handles this natively; CSS transitions reference custom properties that respect the media query.\n823\t- **Keyboard navigation** — Tab zones (Rack → Actions → NMJL → Chat → Controls) with focus-trap regions. Gold focus ring (2px solid, 2px offset) on every interactive element.\n824\t- **No text below 14px** — a floor, not a target. This single rule prevents most readability failures for the 40-70+ demographic.\n825\t\n826\t## Design Direction Decision\n827\t\n828\t### Design Directions Explored\n829\t\n830\tFour layout directions were explored through an interactive HTML showcase (`planning-artifacts/ux-design-directions.html`), all sharing the same visual foundation (felt teal, cream chrome, brushed gold). Each explored different trade-offs in information density, social prominence, and NMJL card accessibility:\n831\t\n832\t- **A: Balanced Panoramic** — NMJL sidebar always visible, video at seats, balanced density. The \"safe\" reference layout.\n833\t- **B: Immersive Table** — Full-width felt, NMJL via overlay, larger video frames, maximum table immersion. Closest to the physical table.\n834\t- **C: Social-Forward** — Chat integrated into main view, prominent video, collapsible NMJL. Social co-presence front and center.\n835\t- **D: Compact Efficient** — Chrome header bar, avatar-only seats, maximum information density. Power-user oriented.\n836\t\n837\t### Chosen Direction\n838\t\n839\t**Direction B: Immersive Table** — Full-width felt surface with no persistent sidebar. Maximum felt immersion and the strongest \"sitting at the table\" feeling. This direction most directly supports the defining experience: \"Play Mahjong with your friends like you're all at the same table.\"\n840\t\n841\t### Design Rationale\n842\t\n843\t1. **Felt immersion supports belonging** — The full-width teal felt surface creates the strongest sense of being at a physical table. No chrome sidebar breaking the illusion.\n844\t2. **Larger video frames strengthen social presence** — With no sidebar competing for horizontal space, video frames at seat positions can be larger (~140x96px on iPad), making faces more recognizable and expressions more readable.\n845\t3. **The primary audience doesn't need the card always visible** — Experienced American Mahjong players (our primary demographic) know the card well. They reference it periodically, not constantly. An overlay toggle is sufficient — and hand guidance highlighting (when implemented in Epic 5B) reduces the need to check the card at all.\n846\t4. **Spacious layout matches the audience's expectations** — Generous spacing signals quality for this demographic. The additional table space from removing the sidebar goes to breathing room, not density.\n847\t5. **Cleanest mobile adaptation** — Without a persistent sidebar to restructure, the layout scales down to phone viewports with fewer breakpoint complications.\n848\t\n849\t### Implementation Approach\n850\t\n851\t**Viewport-Adaptive Element Placement:**\n852\t\n853\t| Element | Desktop (>1024px) | iPad Landscape (~1024px) | Mobile (<1024px) |\n854\t|---|---|---|---|\n855\t| **NMJL Card** | Slide-in panel from right (~280px), overlays felt, tap to toggle | Same as desktop | Full-screen overlay |\n856\t| **Chat** | Slide-in panel from right (mutually exclusive with NMJL) | Slide-up panel from bottom, partial height, rack visible | Slide-up panel from bottom |\n857\t| **Reactions** | Floating vertical stack, right edge, always visible | Same as desktop | Horizontal row above rack, always visible |\n858\t| **Video frames** | ~140x96px at cardinal seat positions | ~120x80px at cardinal seat positions | Small avatars (~40px) with speaking indicators |\n859\t| **Action buttons** | Centered above rack, horizontal row | Same as desktop | Full-width above rack |\n860\t| **Wall counter** | Top center of felt | Same as desktop | Same |\n861\t| **Discard pools** | Generous center area with full-size discard tiles | Same, slightly compressed | Compressed, smaller tiles |\n862\t\n863\t**Charleston NMJL Behavior:**\n864\tDuring Charleston, the NMJL overlay must be positioned so the player's rack remains visible beneath or beside it — never covering the rack entirely. Charleston requires rapid cross-referencing between the card and the rack (check hands, select tiles to pass, recheck, reconsider). A full-screen overlay that hides the rack creates a punishing toggle loop at the game's most cognitively demanding and socially energetic moment. On iPad/desktop, the slide-in panel naturally preserves rack visibility. On mobile, the Charleston-specific NMJL overlay should use a split-view layout: card in the top portion, rack in the bottom.\n865\t\n866\t**Key Layout Rules:**\n867\t- The felt surface is ALWAYS full-width — no persistent chrome panels consuming horizontal space during gameplay\n868\t- All overlays (NMJL, chat) slide over the felt, never restructure the layout beneath\n869\t- NMJL and chat slide-in panels are mutually exclusive — opening one closes the other. No stacking, no ambiguity. Both panels share the same width (~280px), animation tokens (`timing-tactile`, `ease-tactile`), and slide-in direction (from right) so they feel like one architectural element in different modes\n870\t- Floating reactions hide when a slide-in panel (NMJL or chat) is open. This creates two clean states: \"play mode\" (reactions visible, panels closed) and \"reference mode\" (panel open, reactions hidden). This avoids layout shifts and makes conceptual sense — players reading the card or chatting aren't simultaneously reacting\n871\t- Video frames at seat positions are first-class layout elements; when camera is off, avatar circles occupy the same space with no layout shift\n872\t- On mobile, the bottom bar provides toggle access to NMJL overlay, chat panel, and A/V controls\n873\t\n874\t## Player Journey Flows\n875\t\n876\t### 1. Join → Table\n877\t\n878\tThe zero-friction promise: tap a link, type your name, see your friends. Under 10 seconds.\n879\t\n880\t```mermaid\n881\tflowchart TD\n882\t    A[Player taps shared link] --> B[Browser loads game page]\n883\t    B --> C{Room exists & has open seat?}\n884\t    C -->|No / Full| D[Branded 'Table is full' page]\n885\t    D --> E[Option: Enter spectator mode]\n886\t    C -->|Yes| F[Join screen: Enter display name]\n887\t    F --> G[Player taps 'Join']\n888\t    G --> H{Browser mic/camera permissions?}\n889\t    H -->|Already granted| J[Connect A/V streams]\n890\t    H -->|Not yet prompted| I[Friendly permission prompt with guidance]\n891\t    I -->|Granted| J\n892\t    I -->|Denied/Dismissed| K[Continue without A/V — avatar fallback]\n893\t    J --> L[Enter room in Arriving mood]\n894\t    K --> L\n895\t    L --> M[See other players' faces/avatars at seat positions]\n896\t    M --> N{All 4 seats filled?}\n897\t    N -->|No| O[Waiting state — chat and voice active]\n898\t    O --> N\n899\t    N -->|Yes| P[Host sees 'Start Game' button]\n900\t    P --> Q[Host configures settings — timer, card year, Joker rules]\n901\t    Q --> R[Host taps 'Start Game']\n902\t    R --> S[Mood transition: Arriving → Playing]\n903\t    S --> T[Dealing animation — tiles distribute to racks]\n904\t    T --> U[Charleston begins]\n905\t```\n906\t\n907\t**Key UX moments:**\n908\t- **< 10 seconds:** Link tap → seeing friends. No account, no tutorial, no settings gates.\n909\t- **A/V prompt:** One chance, friendly guidance (\"Allow mic so your friends can hear you\"), graceful fallback to avatar if denied.\n910\t- **Arriving mood:** Warm cream dominates, gold is amber, faces and names prominent. The first screen feels like walking into a room, not loading a game.\n911\t- **Waiting state:** Voice chat and text already active. Social energy starts before the game does — this IS \"The Gathering\" peak moment.\n912\t\n913\t---\n914\t\n915\t### 2. Turn Cycle\n916\t\n917\tThe most repeated interaction in the game. Draw → evaluate → (optional Joker exchange) → discard. Must feel effortless by the second turn.\n918\t\n919\t```mermaid\n920\tflowchart TD\n921\t    A{Is it your turn?} -->|No| B[Watch other players — table reading]\n922\t    B --> C[Chat, react, strategize socially]\n923\t    C --> A\n924\t    A -->|Yes — Turn indicator activates| D{East's first turn?}\n925\t    D -->|Yes — 14 tiles, no draw| F[Evaluate hand against NMJL card]\n926\t    D -->|No| E[Tap to draw tile from wall]\n927\t    E --> E1[Tile appears in rack with animation + clack sound]\n928\t    E1 --> E2{Wall now empty?}\n929\t    E2 -->|Yes| E3[Last tile rules — see wall game end state below]\n930\t    E2 -->|No| F\n931\t    F --> G{Drawn tile completes hand?}\n932\t    G -->|Yes| H[Self-drawn Mahjong — go to Declaration flow]\n933\t    G -->|No| I{Want to exchange Joker from exposed group?}\n934\t    I -->|Yes| J[Tap Joker in opponent's exposed group]\n935\t    J --> J1[\"UI shows: 'This Joker = 3-Bam' — matching rack tiles highlighted\"]\n936\t    J1 --> J2{Player has matching natural tile?}\n937\t    J2 -->|No| J3[\"Inline message: 'You need a 3-Bam to exchange'\"]\n938\t    J3 --> I\n939\t    J2 -->|Yes| K[Tap matching natural tile in your rack]\n940\t    K --> L[Joker swaps into your rack, natural tile replaces it]\n941\t    L --> I\n942\t    I -->|No / Done exchanging| M[Select tile to discard — tile lifts]\n943\t    M --> N[Discard confirm button appears in fixed action zone]\n944\t    N --> O{Tap confirm?}\n945\t    O -->|Tap different tile| M\n946\t    O -->|Confirm| P[Tile animates to your discard pool with clack]\n947\t    P --> Q[Call window opens for all other players]\n948\t    Q --> R[Go to Calling flow]\n949\t```\n950\t\n951\t**Wall game end state:** When the wall counter reaches zero, last tile rules apply: the player who draws the final tile may declare self-drawn Mahjong normally. If they discard instead, all other players may call that final discard for any valid purpose (Pung, Kong, Quint, or Mahjong — not restricted to Mahjong only). If no one calls the final discard, the game ends as a wall game (draw) with no payments.\n952\t\n953\t**Key UX moments:**\n954\t- **Turn indicator:** Your seat area glows, obvious from across the room on a propped-up iPad.\n955\t- **Draw:** One tap. Tile appears with animation + sound. No drag, no placement decision.\n956\t- **Joker exchange:** Tap Joker in exposed group → UI displays what tile the Joker substitutes for (e.g., \"This Joker = 3-Bam\") based on the group's fixed identity at exposure time. Matching rack tiles are highlighted. If no match exists, a brief inline message explains why. Multiple exchanges allowed before discarding.\n957\t- **Two-step discard:** Select (tile lifts) → confirm (button appears in fixed action zone). Same place every time. 30+ times per game — must feel rhythmic, not tedious.\n958\t- **Discard pool:** Tiles display in front of your seat in chronological rows (matching physical play) for table reading.\n959\t\n960\t---\n961\t\n962\t### 3. Calling Flow\n963\t\n964\tThe fastest interaction in the game. 3-5 second window. Must be instantly recognizable and forgiving of mistakes.\n965\t\n966\t```mermaid\n967\tflowchart TD\n968\t    A[Tile is discarded — call window opens] --> B[Call buttons appear in fixed action zone]\n969\t    B --> C{Valid calls available?}\n970\t    C -->|No valid calls| D[Only 'Pass' button shown]\n971\t    C -->|Valid calls exist| E[Show valid call buttons: Pung / Kong / Quint / Mahjong]\n972\t    D --> F[Player taps Pass OR timer expires]\n973\t    F --> G{All players passed?}\n974\t    G -->|Yes| H[Next player in turn order draws from wall]\n975\t    G -->|No — others still deciding| I[Wait for remaining players]\n976\t    I --> G\n977\t    E --> J{Player taps a call button?}\n978\t    J -->|No — timer expires| F\n979\t    J -->|Yes| K[Call window FREEZES for all players]\n980\t    K --> K1[\"All players see narration: 'Sarah called Pung — resolving...'\"]\n981\t    K1 --> L{Multiple calls received?}\n982\t    L -->|Mahjong call exists| M[Mahjong takes priority — go to Declaration flow]\n983\t    L -->|Multiple non-Mahjong| N[\"Seat position priority — narrated: 'Linda wins (closer in seat order)'\"]\n984\t    L -->|Single call| O[Winning caller proceeds]\n985\t    N --> O\n986\t    O --> P[Caller selects matching tiles from rack to expose]\n987\t    P --> Q{Valid group formed?}\n988\t    Q -->|No — misclick/mistake| R[Call auto-retracted — no dead hand]\n989\t    R --> S[Call window reopens for remaining time]\n990\t    S --> J\n991\t    Q -->|Yes| T{Player confirms exposure?}\n992\t    T -->|Cancel — still in confirmation phase| R\n993\t    T -->|Confirm| U[Tiles animate into exposed group at caller's seat]\n994\t    U --> V[Called tile joins exposed group — visible to all]\n995\t    V --> W[Play continues counterclockwise FROM CALLER's seat]\n996\t    W --> X[Players between discarder and caller are skipped]\n997\t    X --> Y[Caller must now discard — return to Turn Cycle]\n998\t```\n999\t"}]},"parent_tool_use_id":"toolu_01JHPzXLrwyTqoxi6N3jdNCi","session_id":"e018b2a0-f3f1-40e1-98cc-69fb37f4a59e","uuid":"e60e3755-624a-49cd-b02a-c8585bcd2bfd","timestamp":"2026-03-28T03:09:09.679Z"}
