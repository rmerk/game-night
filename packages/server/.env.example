# LiveKit (voice/video) — server signs JWTs; never expose API secret to the client
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Local dev: allow START_GAME with one human (fills 3 dead-seat ghost seats; never use in production)
# MAHJONG_DEV_SOLO_START=1

# MAHJONG_DEV_SOLO_START is set automatically by `pnpm dev` / `vp run dev` in this package (Unix). Override in .env if needed.
